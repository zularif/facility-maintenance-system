    'EQ051': 'CDA System',    'EQ052': 'CDA System',
    'EQ053': 'Chiller',       'EQ054': 'Chiller',
    'EQ055': 'Cooling Tower', 'EQ056': 'Cooling Tower',
    'EQ057': 'Pump',          'EQ058': 'Pump',          'EQ059': 'Pump',
    'EQ060': 'Chiller',
    'EQ061': 'LV Switchgear', 'EQ062': 'LV Switchgear', 'EQ063': 'LV Switchgear',
    'EQ064': 'LV Switchgear', 'EQ065': 'LV Switchgear', 'EQ066': 'LV Switchgear',
    'EQ067': 'LV Switchgear', 'EQ068': 'LV Switchgear', 'EQ069': 'LV Switchgear',
