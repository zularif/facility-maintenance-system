// ============================================================
// MigrateCategory.gs
// Run migrateCategory() ONCE to populate Category column
// for existing equipment rows that were seeded without it.
// Safe to run multiple times — skips rows that already have a category.
// ============================================================

function migrateCategory() {
  var ss = SpreadsheetApp.openById(CONFIG.SPREADSHEET_ID);
  var sheet = ss.getSheetByName('Equipment');
  var data = sheet.getDataRange().getValues();

  // Detect column positions from header row
  var headers = data[0];
  var equipIDCol = headers.indexOf('EquipID');       // 0
  var cycleCol   = headers.indexOf('InspectionCycle'); // 5
  var catCol     = headers.indexOf('Category');       // 6
  var statusCol  = headers.indexOf('Status');         // 7

  if (catCol < 0) {
    Logger.log('Category column not found. Running addCategoryColumn() first...');
    addCategoryColumn();
    // Re-read headers after inserting column
    data = sheet.getDataRange().getValues();
    headers = data[0];
    catCol = headers.indexOf('Category');
    equipIDCol = headers.indexOf('EquipID');
    if (catCol < 0) {
      Logger.log('ERROR: Still cannot find Category column after addCategoryColumn(). Aborting.');
      return;
    }
    Logger.log('Category column added at column ' + (catCol + 1) + '. Continuing migration...');
  }

  // Category map for all 172 equipment
  var categoryMap = {
    'EQ001': 'HV Switchgear', 'EQ002': 'HV Switchgear', 'EQ003': 'HV Switchgear',
    'EQ004': 'HV Switchgear', 'EQ005': 'HV Switchgear', 'EQ006': 'HV Switchgear',
