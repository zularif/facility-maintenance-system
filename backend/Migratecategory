  var updated = 0;
  var skipped = 0;

  for (var i = 1; i < data.length; i++) {
    var row = data[i];
    if (!row[equipIDCol]) continue; // skip empty rows

    var equipID = row[equipIDCol];
    var existingCat = row[catCol];

    // Skip if already has a category
    if (existingCat && String(existingCat).trim() !== '') {
      skipped++;
      continue;
    }

    var category = categoryMap[equipID] || 'General';
    sheet.getRange(i + 1, catCol + 1).setValue(category);
    updated++;
  }

  SpreadsheetApp.flush();
  Logger.log('migrateCategory() done.');
  Logger.log('Updated: ' + updated + ' rows');
  Logger.log('Skipped (already had category): ' + skipped + ' rows');
}
