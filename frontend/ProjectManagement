<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Management — Factory Maintenance Platform</title>
  <!-- PWA -->
  <link rel="manifest" href="data:application/json;base64,">
  <meta name="theme-color" content="#0EA59E">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="FMP">
  <link rel="apple-touch-icon" href="data:image/png;base64,">
  <meta name="application-name" content="Factory Maintenance Platform">
  <meta name="msapplication-TileColor" content="#1E3A5F">
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Segoe UI, Arial, sans-serif; background: #f3f4f6; color: #1f2937; -webkit-font-smoothing: antialiased; }

    .top-bar {
      background: white; border-bottom: 1px solid #e5e7eb;
      padding: 12px 20px; display: flex; align-items: center; gap: 16px;
      position: sticky; top: 0; z-index: 100; flex-wrap: wrap;
    }
    .top-bar a { font-size: 13px; color: #6b7280; text-decoration: none; display: flex; align-items: center; gap: 4px; }
    .top-bar a:hover { color: #1a56db; }
    .top-bar h1 { font-size: 16px; font-weight: 700; color: #1f2937; flex: 1; }

    .view-toggle { display: flex; background: #f3f4f6; border-radius: 8px; padding: 3px; gap: 2px; }
    .view-toggle button {
      border: none; background: transparent; padding: 6px 14px; font-size: 12px; font-weight: 700;
      border-radius: 6px; cursor: pointer; color: #6b7280; transition: all .15s;
    }
    .view-toggle button.active { background: white; color: #1a56db; box-shadow: 0 1px 2px rgba(0,0,0,.06); }

    .container { max-width: 1900px; margin: 0 auto; padding: 20px; }

    /* Filters */
    .filter-row {
      display: flex; gap: 12px; background: white; border-radius: 12px; border: 1px solid #e5e7eb;
      padding: 16px; margin-bottom: 16px; flex-wrap: wrap; align-items: end;
    }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-label { font-size: 11px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: .4px; }
    .form-input, .form-select, textarea.form-input {
      border: 1px solid #d1d5db; border-radius: 8px; padding: 9px 12px;
      font-size: 13px; color: #1f2937; background: white; outline: none;
      font-family: inherit; transition: border-color .15s;
    }
    .form-select { cursor: pointer; }
    .form-input:focus, .form-select:focus, textarea.form-input:focus { border-color: #1a56db; }
    textarea.form-input { resize: vertical; min-height: 60px; }
    .search-wrap { position: relative; flex: 1; min-width: 180px; }
    .search-wrap svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #9ca3af; }
    .search-wrap input { width: 100%; padding-left: 34px; }

    .btn {
      padding: 9px 16px; border-radius: 8px; font-size: 13px; font-weight: 700;
      border: none; cursor: pointer; transition: all .15s; white-space: nowrap;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-primary { background: #1a56db; color: white; }
    .btn-primary:hover { background: #1648c4; }
    .btn-ghost { background: transparent; color: #6b7280; border: 1px solid #d1d5db; }
    .btn-ghost:hover { background: #f3f4f6; }
    .btn-danger { background: #fef2f2; color: #dc2626; }
    .btn-danger:hover { background: #fee2e2; }
    .btn-export { background: #16a34a; color: white; }
    .btn-export:hover { background: #15803d; }
    .btn-sm { padding: 5px 10px; font-size: 12px; }

    /* Badges */
    .badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; white-space: nowrap; }
    .badge-backlog     { background: #f3f4f6; color: #6b7280; }
    .badge-planned     { background: #eff6ff; color: #1a56db; }
    .badge-inprogress  { background: #fff7ed; color: #ea580c; }
    .badge-onhold      { background: #f5f3ff; color: #7c3aed; }
    .badge-completed   { background: #f0fdf4; color: #16a34a; }
    .badge-prio-low    { background: #f3f4f6; color: #6b7280; }
    .badge-prio-medium { background: #eff6ff; color: #1a56db; }
    .badge-prio-high   { background: #fef2f2; color: #dc2626; }
    .badge-cat         { background: #f5f3ff; color: #7c3aed; }
    .badge-type        { background: #f3f4f6; color: #6b7280; font-size: 10px; }

    /* Progress bar */
    .progress-wrap { display: flex; align-items: center; gap: 6px; min-width: 90px; }
    .progress-track { flex: 1; height: 6px; background: #e5e7eb; border-radius: 4px; overflow: hidden; }
    .progress-fill { height: 100%; background: #1a56db; border-radius: 4px; }
    .progress-fill.complete { background: #16a34a; }
    .progress-text { font-size: 11px; color: #6b7280; font-weight: 700; min-width: 32px; text-align: right; }

    /* Table */
    .table-card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; }
    .table-wrap { overflow-x: auto; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 12px; min-width: 1100px; }
    .data-table th {
      background: #f9fafb; color: #6b7280; font-weight: 700; text-transform: uppercase;
      font-size: 10px; letter-spacing: .4px; padding: 10px 12px; text-align: left;
      border-bottom: 1px solid #e5e7eb; white-space: nowrap;
    }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #f3f4f6; vertical-align: top; }
    .data-table tr.row-project:hover td { background: #f9fafb; }
    .data-table tr.row-task td { background: #fbfbfc; }
    .data-table tr.row-task:hover td { background: #f3f4f6; }
    .cell-clip { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 240px; }
    .cell-wrap { display: block; max-width: 260px; white-space: normal; line-height: 1.4; }
    .table-empty { text-align: center; padding: 40px; color: #9ca3af; }
    .row-chevron { display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; cursor: pointer; color: #6b7280; transition: transform .15s; vertical-align: middle; }
    .row-chevron.open { transform: rotate(90deg); }
    .task-indent { padding-left: 28px; color: #4b5563; }
    .task-bullet { color: #9ca3af; margin-right: 4px; }
    .task-grip { color: #c0c4cc; cursor: grab; vertical-align: middle; margin-right: 4px; }
    .row-task:hover .task-grip { color: #9ca3af; }
    tr.row-task[draggable="true"] { cursor: default; }

    /* Kanban */
    .kanban-board { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; align-items: start; }
    .kanban-col { background: #eef0f3; border-radius: 12px; padding: 10px; min-height: 200px; }
    .kanban-col-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; padding: 0 4px; }
    .kanban-col-title { font-size: 12px; font-weight: 700; color: #374151; }
    .kanban-col-count { font-size: 11px; font-weight: 700; background: white; color: #6b7280; border-radius: 12px; padding: 2px 8px; }
    .kanban-cards { display: flex; flex-direction: column; gap: 8px; min-height: 60px; }
    .kanban-col.drag-over { background: #dbeafe; outline: 2px dashed #1a56db; }
    .kanban-card {
      background: white; border-radius: 10px; padding: 10px; cursor: grab;
      border: 1px solid #e5e7eb; box-shadow: 0 1px 2px rgba(0,0,0,.04);
    }
    .kanban-card:active { cursor: grabbing; }
    .kanban-card.dragging { opacity: .4; }
    .kanban-card-title { font-size: 12.5px; font-weight: 700; color: #1f2937; margin-bottom: 4px; line-height: 1.3; }
    .kanban-card-meta { font-size: 11px; color: #6b7280; margin-bottom: 8px; }
    .kanban-card-footer { display: flex; align-items: center; justify-content: space-between; gap: 6px; flex-wrap: wrap; }
    .kanban-empty { text-align: center; padding: 20px 8px; color: #9ca3af; font-size: 12px; }

    /* Gantt */
    .gantt-card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; padding: 16px; }
    .gantt-toolbar { display: flex; gap: 8px; margin-bottom: 12px; }
    .gantt-toolbar button {
      border: 1px solid #d1d5db; background: white; padding: 6px 14px; border-radius: 8px;
      font-size: 12px; font-weight: 700; cursor: pointer; color: #6b7280;
    }
    .gantt-toolbar button.active { border-color: #1a56db; color: #1a56db; background: #eff6ff; }
    .gantt-legend { display: flex; gap: 14px; margin-top: 12px; flex-wrap: wrap; font-size: 12px; color: #6b7280; }
    .gantt-legend span { display: inline-flex; align-items: center; gap: 6px; }
    .gantt-legend .sw { width: 12px; height: 12px; border-radius: 3px; }

    .gantt-wrap { display: flex; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; }
    .gantt-left { width: 380px; flex-shrink: 0; border-right: 1px solid #e5e7eb; overflow: hidden; }
    .gantt-right-scroll { flex: 1; overflow-x: auto; }
    .gantt-right { position: relative; }
    .gantt-row {
      display: flex; align-items: center; height: 38px; box-sizing: border-box;
      border-bottom: 1px solid #f3f4f6; font-size: 12px; position: relative; cursor: pointer;
    }
    .gantt-row.header-row {
      height: 32px; background: #f9fafb; font-weight: 700; font-size: 10px;
      text-transform: uppercase; color: #6b7280; letter-spacing: .4px;
      border-bottom: 1px solid #e5e7eb; cursor: default;
    }
    .gantt-left .gantt-row { padding: 0 10px; gap: 8px; }
    .g-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .g-name.task-indent { padding-left: 16px; color: #4b5563; }
    .g-owner { width: 90px; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #6b7280; }
    .g-progress { width: 90px; flex-shrink: 0; display: flex; align-items: center; gap: 6px; }
    .g-progress .progress-track { flex: 1; height: 5px; background: #e5e7eb; border-radius: 4px; overflow: hidden; }
    .g-progress .progress-fill { height: 100%; background: #1a56db; border-radius: 4px; }
    .g-progress .progress-fill.complete { background: #16a34a; }
    .g-progress-text { font-size: 11px; color: #6b7280; min-width: 28px; text-align: right; }

    .g-col-label { flex-shrink: 0; border-right: 1px solid #f3f4f6; padding: 0 8px; box-sizing: border-box; display: flex; align-items: center; }
    .g-bar {
      position: absolute; top: 6px; height: 26px; border-radius: 6px; overflow: hidden;
      display: flex; align-items: center; min-width: 6px;
    }
    .g-bar-fill { position: absolute; top: 0; left: 0; height: 100%; background: rgba(0,0,0,.15); }
    .g-bar-label { position: relative; z-index: 1; font-size: 11px; font-weight: 600; padding: 0 6px; white-space: nowrap; overflow: hidden; }
    .g-bar-overlay { position: absolute; inset: 0; display: flex; align-items: stretch; }
    .g-handle-left, .g-handle-right { width: 8px; flex-shrink: 0; cursor: ew-resize; }
    .g-handle-left:hover, .g-handle-right:hover { background: rgba(0,0,0,.12); }
    .g-handle-move { flex: 1; cursor: grab; display: flex; align-items: center; overflow: hidden; }
    .g-today-line { position: absolute; top: 0; width: 2px; background: #dc2626; z-index: 2; pointer-events: none; }

    /* Calendar */
    .cal-card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; padding: 16px; }
    .cal-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .cal-toolbar h2 { font-size: 15px; font-weight: 700; }
    .cal-toolbar .nav { display: flex; gap: 6px; }
    .cal-toolbar button { border: 1px solid #d1d5db; background: white; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; color: #6b7280; }
    .cal-toolbar button:hover { background: #f3f4f6; }
    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; background: #e5e7eb; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; }
    .cal-dow { background: #f9fafb; text-align: center; font-size: 11px; font-weight: 700; color: #6b7280; padding: 6px; text-transform: uppercase; }
    .cal-cell { background: white; min-height: 90px; padding: 6px; }
    .cal-cell.other-month { background: #fafafa; color: #d1d5db; }
    .cal-cell.today { background: #eff6ff; }
    .cal-date { font-size: 11px; font-weight: 700; color: #6b7280; margin-bottom: 4px; }
    .cal-chip {
      font-size: 10px; font-weight: 600; padding: 2px 6px; border-radius: 4px; margin-bottom: 3px;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: pointer; display: block;
    }
    .cal-chip-backlog    { background: #f3f4f6; color: #6b7280; }
    .cal-chip-planned    { background: #dbeafe; color: #1a56db; }
    .cal-chip-inprogress { background: #ffedd5; color: #ea580c; }
    .cal-chip-onhold     { background: #ede9fe; color: #7c3aed; }
    .cal-chip-completed  { background: #dcfce7; color: #16a34a; }

    /* Modal */
    .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4);
      align-items: center; justify-content: center; z-index: 1000; padding: 16px;
    }
    .modal-overlay.open { display: flex; }
    .modal { background: white; border-radius: 14px; max-width: 640px; width: 100%; max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 22px; border-bottom: 1px solid #e5e7eb; }
    .modal-title { font-size: 15px; font-weight: 700; }
    .modal-close { border: none; background: none; font-size: 18px; cursor: pointer; color: #9ca3af; line-height: 1; }
    .modal-body { padding: 18px 22px; display: flex; flex-direction: column; gap: 14px; }
    .modal-footer { display: flex; justify-content: space-between; gap: 8px; padding: 16px 22px; border-top: 1px solid #e5e7eb; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    .required { color: #dc2626; }
    .field-hint { font-size: 11px; color: #9ca3af; margin-top: 2px; }
    input[type="range"] { width: 100%; }

    .empty-state { text-align: center; padding: 60px 20px; color: #9ca3af; }
    .empty-state svg { width: 48px; height: 48px; margin: 0 auto 12px; display: block; opacity: .4; }
    .empty-state h3 { font-size: 14px; color: #6b7280; margin-bottom: 4px; }
    .empty-state p { font-size: 12px; }

    .spinner-wrap { display: flex; align-items: center; justify-content: center; padding: 60px; gap: 12px; }
    .spinner { width: 28px; height: 28px; border: 3px solid #e5e7eb; border-top-color: #1a56db; border-radius: 50%; animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 1024px) {
      .kanban-board { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .kanban-board { grid-template-columns: 1fr; }
      .form-row, .form-row-3 { grid-template-columns: 1fr; }
      .filter-row { flex-direction: column; align-items: stretch; }
      .cal-grid { grid-template-columns: repeat(7, minmax(36px,1fr)); }
      .cal-cell { min-height: 60px; padding: 3px; font-size: 10px; }
    }
  </style>
</head>
<body>

<div class="top-bar">
  <a href="#" onclick="history.back(); return false;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Back
  </a>
  <h1>&#128203; Project Management</h1>
  <div class="view-toggle">
    <button id="vt-table" class="active" onclick="setView('table')">Table</button>
    <button id="vt-kanban" onclick="setView('kanban')">Kanban</button>
    <button id="vt-gantt" onclick="setView('gantt')">Gantt</button>
    <button id="vt-calendar" onclick="setView('calendar')">Calendar</button>
  </div>
</div>

<div class="container">

  <!-- Filters -->
  <div class="filter-row">
    <div class="search-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="form-input" id="f-search" placeholder="Search project or task..." oninput="renderCurrentView()">
    </div>
    <div class="form-group">
      <label class="form-label">Plant</label>
      <select class="form-select" id="f-plant" onchange="loadAll()">
        <option value="">All Plants</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Category</label>
      <select class="form-select" id="f-category" onchange="renderCurrentView()">
        <option value="">All Categories</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Owner</label>
      <select class="form-select" id="f-owner" onchange="renderCurrentView()">
        <option value="">All Owners</option>
      </select>
    </div>
    <button class="btn btn-export" onclick="exportExcel()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export
    </button>
    <button class="btn btn-primary" onclick="openProjectModal(null)">+ Add Project</button>
  </div>

  <!-- Table View -->
  <div id="view-table-wrap">
    <div class="table-card">
      <div class="table-wrap">
        <table class="data-table">
          <thead><tr>
            <th>Name</th><th>Plant</th><th>Category</th><th>Owner</th><th>Status</th>
            <th>Priority</th><th>Start</th><th>Due</th><th>Progress</th><th>Notes</th><th>Actions</th>
          </tr></thead>
          <tbody id="pm-tbody"><tr><td colspan="11" class="table-empty">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Kanban View -->
  <div id="view-kanban-wrap" style="display:none">
    <div class="kanban-board" id="kanban-board"></div>
  </div>

  <!-- Gantt View -->
  <div id="view-gantt-wrap" style="display:none">
    <div class="gantt-card">
      <div class="gantt-toolbar" id="gantt-toolbar">
        <button onclick="setGanttMode('Day')" data-mode="Day">Day</button>
        <button onclick="setGanttMode('Week')" data-mode="Week" class="active">Week</button>
        <button onclick="setGanttMode('Month')" data-mode="Month">Month</button>
      </div>
      <div class="gantt-wrap" id="gantt-wrap" style="display:none">
        <div class="gantt-left" id="gantt-left"></div>
        <div class="gantt-right-scroll"><div class="gantt-right" id="gantt-right"></div></div>
      </div>
      <div class="empty-state" id="gantt-empty" style="display:none">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <h3>No scheduled items</h3><p>Add a project or task with start/due dates to see it here.</p>
      </div>
      <div class="gantt-legend">
        <span><span class="sw" style="background:#c7d2fe"></span>Project (no tasks)</span>
        <span><span class="sw" style="background:#e5e7eb"></span>Backlog</span>
        <span><span class="sw" style="background:#93c5fd"></span>Planned</span>
        <span><span class="sw" style="background:#fdba74"></span>In Progress</span>
        <span><span class="sw" style="background:#c4b5fd"></span>On Hold</span>
        <span><span class="sw" style="background:#86efac"></span>Completed</span>
        <span style="color:#9ca3af"><span class="sw" style="background:#dc2626;width:2px"></span>Today</span>
        <span style="color:#9ca3af">Click a row to edit</span>
        <span style="color:#9ca3af">Drag a task bar to move/resize</span>
      </div>
    </div>
  </div>

  <!-- Calendar View -->
  <div id="view-calendar-wrap" style="display:none">
    <div class="cal-card">
      <div class="cal-toolbar">
        <h2 id="cal-title">Month Year</h2>
        <div class="nav">
          <button onclick="calNav(-1)">&#8249; Prev</button>
          <button onclick="calToday()">Today</button>
          <button onclick="calNav(1)">Next &#8250;</button>
        </div>
      </div>
      <div class="cal-grid" id="cal-grid"></div>
    </div>
  </div>

</div>

<!-- Project Modal -->
<div class="modal-overlay" id="modal-project">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title" id="project-modal-title">Add Project</span>
      <button class="modal-close" onclick="closeModal('modal-project')">&#10005;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="project-id">

      <div class="form-group">
        <label class="form-label">Project Name <span class="required">*</span></label>
        <input type="text" class="form-input" id="project-name" placeholder="e.g. Chiller Plant Upgrade 2026">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Plant <span class="required">*</span></label>
          <select class="form-select" id="project-plant"><option value="">-- Select Plant --</option></select>
        </div>
        <div class="form-group">
          <label class="form-label">Category</label>
          <select class="form-select" id="project-category"></select>
        </div>
      </div>

      <div class="form-group">
