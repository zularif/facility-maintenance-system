// ── TASK MODAL ────────────────────────────────────────────
function openTaskModal(taskID, projectID) {
  document.getElementById('task-id').value = '';
  document.getElementById('task-project-id').value = '';
  document.getElementById('task-name').value = '';
  document.getElementById('task-owner').value = '';
  document.getElementById('task-status').value = 'Backlog';
  document.getElementById('task-priority').value = 'Medium';
  document.getElementById('task-start').value = '';
  document.getElementById('task-due').value = '';
  document.getElementById('task-progress').value = 0;
  document.getElementById('task-progress-val').textContent = '0%';
  document.getElementById('task-notes').value = '';
  document.getElementById('task-delete-btn').style.display = 'none';

  if (taskID) {
    // Find task — search loaded project task lists, fall back to PM.allTasks
    var t = null, parentProjectID = null;
    for (var pid in PM.tasksByProject) {
      var found = (PM.tasksByProject[pid] || []).find(function(x){ return x.taskID === taskID; });
      if (found) { t = found; parentProjectID = pid; break; }
    }
    if (!t) {
      var at = PM.allTasks.find(function(x){ return x.taskID === taskID; });
      if (at) { t = at; parentProjectID = at.projectID; }
    }
    if (!t) return;

    var proj = PM.projects.find(function(x){ return x.projectID === parentProjectID; });
    document.getElementById('task-modal-title').textContent = 'Edit Task \u2014 ' + t.taskID;
    document.getElementById('task-id').value = t.taskID;
    document.getElementById('task-project-id').value = parentProjectID;
    document.getElementById('task-project-name').textContent = proj ? ('Project: ' + proj.projectName) : '';
    document.getElementById('task-name').value = t.taskName;
    document.getElementById('task-owner').value = t.owner;
    document.getElementById('task-status').value = t.status;
    document.getElementById('task-priority').value = t.priority;
    document.getElementById('task-start').value = t.startDate;
    document.getElementById('task-due').value = t.dueDate;
    document.getElementById('task-progress').value = t.progress;
    document.getElementById('task-progress-val').textContent = t.progress + '%';
    document.getElementById('task-notes').value = t.notes;
    document.getElementById('task-delete-btn').style.display = 'inline-flex';
  } else {
    var p = PM.projects.find(function(x){ return x.projectID === projectID; });
    document.getElementById('task-modal-title').textContent = 'Add Task';
    document.getElementById('task-project-id').value = projectID;
    document.getElementById('task-project-name').textContent = p ? ('Project: ' + p.projectName) : '';
    document.getElementById('task-due').value = '';
  }

  openModal('modal-task');
}

function saveTaskForm() {
  var name = document.getElementById('task-name').value.trim();
  var projectID = document.getElementById('task-project-id').value;
  if (!name) { alert('Please enter a task name.'); return; }
  if (!projectID) { alert('No parent project set.'); return; }

  var payload = {
    taskID: document.getElementById('task-id').value || null,
    projectID: projectID,
    taskName: name,
    owner: document.getElementById('task-owner').value.trim(),
    status: document.getElementById('task-status').value,
    priority: document.getElementById('task-priority').value,
    startDate: document.getElementById('task-start').value,
    dueDate: document.getElementById('task-due').value,
    progress: parseInt(document.getElementById('task-progress').value, 10) || 0,
    notes: document.getElementById('task-notes').value.trim()
  };

  var btn = document.querySelector('#modal-task .btn-primary');
  btn.disabled = true; btn.textContent = 'Saving...';
  gasCall('saveProjectTask', payload).then(function(result) {
    btn.disabled = false; btn.textContent = 'Save Task';
    if (!result || !result.success) { alert('Save failed: ' + ((result && result.error) || 'Unknown error')); return; }
    closeModal('modal-task');
    PM.expandedProjects[projectID] = true;
    delete PM.tasksByProject[projectID]; // force reload of this project's tasks
    loadAll();
  }).catch(function(e) {
    btn.disabled = false; btn.textContent = 'Save Task';
    alert('Save error: ' + e.message);
  });
}

// ── DELETE ────────────────────────────────────────────────
function deleteConfirm(type) {
  PM.deleteCtx = { type: type, id: type === 'project' ? document.getElementById('project-id').value : document.getElementById('task-id').value };
  document.getElementById('confirm-text').textContent = type === 'project' ? 'Delete this project and all its tasks?' : 'Delete this task?';
  openModal('modal-confirm');
}

function confirmDelete() {
  if (!PM.deleteCtx) return;
  var ctx = PM.deleteCtx; PM.deleteCtx = null;
  var fn = ctx.type === 'project' ? 'deleteProject' : 'deleteProjectTask';
  gasCall(fn, ctx.id).then(function(result) {
    closeModal('modal-confirm');
    closeModal(ctx.type === 'project' ? 'modal-project' : 'modal-task');
    if (result && result.success) loadAll();
    else alert('Delete failed: ' + ((result && result.error) || 'Unknown error'));
  }).catch(function(e) {
    closeModal('modal-confirm');
    alert('Delete error: ' + e.message);
  });
}

// ── EXPORT ────────────────────────────────────────────────
function exportExcel() {
  var rows = getFilteredProjects();
  if (!rows.length) { alert('No projects to export.'); return; }

  var data = [];
  rows.forEach(function(p) {
    data.push({
      'Type': 'Project', 'Name': p.projectName, 'Plant': p.plantName, 'Category': p.category,
      'Owner': p.owner, 'Status': p.status, 'Priority': p.priority,
      'Start': p.startDate, 'Due': p.dueDate, 'Progress': p.progress, 'Notes': p.description || p.notes
    });
    var tasks = PM.allTasks.filter(function(t) { return t.projectID === p.projectID; });
    tasks.forEach(function(t) {
      data.push({
        'Type': '  Task', 'Name': t.taskName, 'Plant': '', 'Category': '',
        'Owner': t.owner, 'Status': t.status, 'Priority': t.priority,
        'Start': t.startDate, 'Due': t.dueDate, 'Progress': t.progress, 'Notes': t.notes
      });
    });
  });

  var ws = XLSX.utils.json_to_sheet(data);
  ws['!cols'] = [{wch:8},{wch:34},{wch:14},{wch:18},{wch:16},{wch:12},{wch:10},{wch:12},{wch:12},{wch:10},{wch:34}];
  var wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Projects');
  XLSX.writeFile(wb, 'project_management_' + todayStr() + '.xlsx');
}
</script>
