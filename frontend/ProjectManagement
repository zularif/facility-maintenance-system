<script>
var PM = {
  plants: [], categories: [], statuses: [], priorities: [], technicians: [],
  projects: [], tasksByProject: {}, expandedProjects: {},
  allTasks: [], soloProjects: [],
  view: 'table',
  ganttMode: 'Week',
  calMonth: new Date(),
  deleteCtx: null
};

function gasCall(fn) {
  var args = Array.prototype.slice.call(arguments, 1);
  return new Promise(function(resolve, reject) {
    google.script.run.withSuccessHandler(resolve).withFailureHandler(reject)[fn].apply(google.script.run, args);
  });
}

function esc(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function fmtDate(d) {
  if (!d) return '';
  var parts = d.split('-');
  if (parts.length !== 3) return d;
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return parseInt(parts[2],10) + ' ' + months[parseInt(parts[1],10)-1] + ' ' + parts[0];
}

function todayStr() {
  var d = new Date();
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}

function statusClass(status) {
  return 'badge-' + String(status || 'Backlog').toLowerCase().replace(/\s/g, '');
}
function prioClass(p) {
  return 'badge-prio-' + String(p || 'Medium').toLowerCase();
}
function calChipClass(status) {
  return 'cal-chip-' + String(status || 'Backlog').toLowerCase().replace(/\s/g, '');
}

// ── INIT ─────────────────────────────────────────────────
window.addEventListener('load', function() {
  if (typeof google === 'undefined' || !google.script) {
    document.getElementById('pm-tbody').innerHTML = '<tr><td colspan="11" class="table-empty">Error: open via the deployed web app URL.</td></tr>';
    return;
  }
  Promise.all([gasCall('getProjectMeta'), gasCall('getTechnicians')]).then(function(results) {
    var meta = results[0] || {};
    PM.plants = meta.plants || [];
    PM.categories = meta.categories || [];
    PM.statuses = meta.statuses || ['Backlog','Planned','In Progress','On Hold','Completed'];
    PM.priorities = meta.priorities || ['Low','Medium','High'];
    PM.technicians = (results[1] && Array.isArray(results[1])) ? results[1] : [];

    var plantSel = document.getElementById('f-plant');
    plantSel.innerHTML = '<option value="">All Plants</option>' +
      PM.plants.map(function(p){ return '<option value="' + p.plantID + '">' + esc(p.plantName) + '</option>'; }).join('');

    var catSel = document.getElementById('f-category');
    catSel.innerHTML = '<option value="">All Categories</option>' +
      PM.categories.map(function(c){ return '<option value="' + esc(c) + '">' + esc(c) + '</option>'; }).join('');

    // Modal dropdowns
    document.getElementById('project-plant').innerHTML = '<option value="">-- Select Plant --</option>' +
      PM.plants.map(function(p){ return '<option value="' + p.plantID + '">' + esc(p.plantName) + '</option>'; }).join('');
    document.getElementById('project-category').innerHTML =
      PM.categories.map(function(c){ return '<option value="' + esc(c) + '">' + esc(c) + '</option>'; }).join('');
    document.getElementById('project-status').innerHTML =
      PM.statuses.map(function(s){ return '<option value="' + esc(s) + '">' + esc(s) + '</option>'; }).join('');
    document.getElementById('project-priority').innerHTML =
      PM.priorities.map(function(p){ return '<option value="' + esc(p) + '">' + esc(p) + '</option>'; }).join('');
    document.getElementById('task-status').innerHTML =
      PM.statuses.map(function(s){ return '<option value="' + esc(s) + '">' + esc(s) + '</option>'; }).join('');
    document.getElementById('task-priority').innerHTML =
      PM.priorities.map(function(p){ return '<option value="' + esc(p) + '">' + esc(p) + '</option>'; }).join('');

    var picList = document.getElementById('pm-pic-list');
    picList.innerHTML = PM.technicians.map(function(t){ return '<option value="' + esc(t.name) + '">'; }).join('');

    loadAll();
  }).catch(function(e) {
    document.getElementById('pm-tbody').innerHTML = '<tr><td colspan="11" class="table-empty">Error: ' + esc(e.message || String(e)) + '</td></tr>';
  });
});

function loadAll() {
  var plantID = document.getElementById('f-plant').value;
  document.getElementById('pm-tbody').innerHTML = '<tr><td colspan="11"><div class="spinner-wrap"><div class="spinner"></div></div></td></tr>';
  PM.tasksByProject = {};
  PM.expandedProjects = {};

  Promise.all([gasCall('getProjects', plantID), gasCall('getAllProjectTasks', plantID)]).then(function(results) {
    var projects = results[0];
    var taskData = results[1];
    if (projects && projects.error) throw new Error(projects.error);
    if (taskData && taskData.error) throw new Error(taskData.error);

    PM.projects = projects || [];
    PM.allTasks = (taskData && taskData.tasks) || [];
    PM.soloProjects = (taskData && taskData.soloProjects) || [];

    populateOwnerFilter();
    renderCurrentView();
  }).catch(function(e) {
    document.getElementById('pm-tbody').innerHTML = '<tr><td colspan="11" class="table-empty">Error: ' + esc(e.message || String(e)) + '</td></tr>';
  });
}

// ── VIEW SWITCHING ──────────────────────────────────────
function setView(view) {
  PM.view = view;
  ['table','kanban','gantt','calendar'].forEach(function(v) {
    document.getElementById('vt-' + v).classList.toggle('active', v === view);
    document.getElementById('view-' + v + '-wrap').style.display = (v === view) ? 'block' : 'none';
  });
  renderCurrentView();
}

function renderCurrentView() {
  if (PM.view === 'table') renderTable();
  else if (PM.view === 'kanban') renderKanban();
  else if (PM.view === 'gantt') renderGantt();
  else renderCalendar();
}

function getSearchTerm() { return (document.getElementById('f-search').value || '').toLowerCase(); }
function getCategoryFilter() { return document.getElementById('f-category').value; }
function getOwnerFilter() { return document.getElementById('f-owner').value; }

function populateOwnerFilter() {
  var owners = {};
  PM.projects.forEach(function(p) { if (p.owner) owners[p.owner] = true; });
  PM.allTasks.forEach(function(t) { if (t.owner) owners[t.owner] = true; });
  var sorted = Object.keys(owners).sort(function(a,b){ return a.localeCompare(b); });
  var sel = document.getElementById('f-owner');
  var current = sel.value;
  sel.innerHTML = '<option value="">All Owners</option>' +
    sorted.map(function(o){ return '<option value="' + esc(o) + '">' + esc(o) + '</option>'; }).join('');
  sel.value = sorted.indexOf(current) >= 0 ? current : '';
}

// Tasks matching the current owner filter (or all tasks if no filter)
function getVisibleTasks() {
  var owner = getOwnerFilter();
  if (!owner) return PM.allTasks;
  return PM.allTasks.filter(function(t) { return t.owner === owner; });
}

// A project is visible if its own owner matches, or it has at least one matching task
function projectMatchesOwner(p, visibleTasks) {
  var owner = getOwnerFilter();
  if (!owner) return true;
  if (p.owner === owner) return true;
  return visibleTasks.some(function(t) { return t.projectID === p.projectID; });
}

function getFilteredProjects() {
  var cat = getCategoryFilter();
  var term = getSearchTerm();
  var visibleTasks = getVisibleTasks();
  return PM.projects.filter(function(p) {
    if (cat && p.category !== cat) return false;
    if (!projectMatchesOwner(p, visibleTasks)) return false;
    if (term && p.projectName.toLowerCase().indexOf(term) < 0) {
      // also check its tasks
      var tasks = PM.tasksByProject[p.projectID] || [];
      var taskMatch = tasks.some(function(t) { return t.taskName.toLowerCase().indexOf(term) >= 0; });
      if (!taskMatch) return false;
    }
    return true;
  });
}

// ── TABLE VIEW ────────────────────────────────────────────
function renderTable() {
  var rows = getFilteredProjects();
  var tbody = document.getElementById('pm-tbody');
  if (!rows.length) {
    tbody.innerHTML = '<tr><td colspan="11" class="table-empty">No projects found. Click "+ Add Project" to create one.</td></tr>';
    return;
  }
  tbody.innerHTML = rows.map(function(p) { return renderProjectRow(p); }).join('');
}

function renderProjectRow(p) {
  var isOpen = !!PM.expandedProjects[p.projectID];
  var progressCls = p.progress >= 100 ? ' complete' : '';
  var html = '<tr class="row-project">' +
    '<td>' +
      '<span class="row-chevron' + (isOpen ? ' open' : '') + '" onclick="toggleProject(\'' + p.projectID + '\')">' +
        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>' +
      '</span> ' +
      '<strong>' + esc(p.projectName) + '</strong>' +
      (p.taskCount ? ' <span class="badge badge-type">' + p.taskCount + ' task' + (p.taskCount===1?'':'s') + '</span>' : '') +
    '</td>' +
    '<td><span class="cell-clip">' + esc(p.plantName) + '</span></td>' +
    '<td><span class="badge badge-cat">' + esc(p.category || '\u2013') + '</span></td>' +
    '<td><span class="cell-clip">' + esc(p.owner || '\u2013') + '</span></td>' +
    '<td><span class="badge ' + statusClass(p.status) + '">' + esc(p.status) + '</span></td>' +
    '<td><span class="badge ' + prioClass(p.priority) + '">' + esc(p.priority) + '</span></td>' +
    '<td><span class="cell-clip">' + (p.startDate ? fmtDate(p.startDate) : '\u2013') + '</span></td>' +
    '<td><span class="cell-clip">' + (p.dueDate ? fmtDate(p.dueDate) : '\u2013') + '</span></td>' +
    '<td><div class="progress-wrap"><div class="progress-track"><div class="progress-fill' + progressCls + '" style="width:' + p.progress + '%"></div></div><span class="progress-text">' + p.progress + '%</span></div></td>' +
    '<td><span class="cell-wrap">' + esc(p.description || p.notes || '\u2013') + '</span></td>' +
    '<td>' +
      '<button class="btn btn-ghost btn-sm" onclick="openProjectModal(\'' + p.projectID + '\')">Edit</button> ' +
      '<button class="btn btn-ghost btn-sm" onclick="openTaskModal(null, \'' + p.projectID + '\')">+Task</button>' +
    '</td>' +
  '</tr>';

  if (isOpen) {
    var tasks = PM.tasksByProject[p.projectID];
    if (!tasks) {
      html += '<tr class="row-task"><td colspan="11" class="task-indent"><div class="spinner-wrap" style="padding:16px"><div class="spinner"></div></div></td></tr>';
    } else if (!tasks.length) {
      html += '<tr class="row-task"><td colspan="11" class="task-indent" style="color:#9ca3af">No tasks yet. Click "+Task" to add one.</td></tr>';
    } else {
      var owner = getOwnerFilter();
      var visibleTaskList = owner ? tasks.filter(function(t){ return t.owner === owner; }) : tasks;
      if (!visibleTaskList.length) {
        html += '<tr class="row-task"><td colspan="11" class="task-indent" style="color:#9ca3af">No tasks assigned to ' + esc(owner) + ' in this project.</td></tr>';
      } else {
        visibleTaskList.forEach(function(t) { html += renderTaskRow(t, p); });
      }
    }
  }
  return html;
}

function renderTaskRow(t, project) {
  var progressCls = t.progress >= 100 ? ' complete' : '';
  var draggableOn = !getOwnerFilter(); // reordering only meaningful on the unfiltered list
  var dragAttrs = draggableOn
    ? ' draggable="true" ondragstart="onTaskDragStart(event,\'' + t.taskID + '\',\'' + project.projectID + '\')"' +
      ' ondragover="onTaskDragOver(event,\'' + t.taskID + '\',\'' + project.projectID + '\')"' +
      ' ondragend="onTaskDragEnd(event)"'
    : '';
  var grip = draggableOn
    ? '<svg class="task-grip" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="6" r="1.5"/><circle cx="15" cy="6" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="18" r="1.5"/><circle cx="15" cy="18" r="1.5"/></svg>'
    : '';
  return '<tr class="row-task"' + dragAttrs + '>' +
    '<td class="task-indent">' + grip + '<span class="task-bullet">&#8627;</span>' + esc(t.taskName) + '</td>' +
    '<td>\u2013</td>' +
    '<td>\u2013</td>' +
    '<td><span class="cell-clip">' + esc(t.owner || '\u2013') + '</span></td>' +
    '<td><span class="badge ' + statusClass(t.status) + '">' + esc(t.status) + '</span></td>' +
    '<td><span class="badge ' + prioClass(t.priority) + '">' + esc(t.priority) + '</span></td>' +
    '<td><span class="cell-clip">' + (t.startDate ? fmtDate(t.startDate) : '\u2013') + '</span></td>' +
    '<td><span class="cell-clip">' + (t.dueDate ? fmtDate(t.dueDate) : '\u2013') + '</span></td>' +
    '<td><div class="progress-wrap"><div class="progress-track"><div class="progress-fill' + progressCls + '" style="width:' + t.progress + '%"></div></div><span class="progress-text">' + t.progress + '%</span></div></td>' +
    '<td><span class="cell-wrap">' + esc(t.notes || '\u2013') + '</span></td>' +
    '<td><button class="btn btn-ghost btn-sm" onclick="openTaskModal(\'' + t.taskID + '\', \'' + project.projectID + '\')">Edit</button></td>' +
  '</tr>';
}

// ── Task drag-to-reorder (within a project, table view) ────
var dragTaskCtx = null;

function onTaskDragStart(e, taskID, projectID) {
  dragTaskCtx = { taskID: taskID, projectID: projectID };
  e.dataTransfer.effectAllowed = 'move';
}

function onTaskDragOver(e, overTaskID, overProjectID) {
  e.preventDefault();
  if (!dragTaskCtx || dragTaskCtx.projectID !== overProjectID || dragTaskCtx.taskID === overTaskID) return;
  var list = PM.tasksByProject[overProjectID];
  if (!list) return;
  var fromIdx = list.findIndex(function(t) { return t.taskID === dragTaskCtx.taskID; });
  var toIdx = list.findIndex(function(t) { return t.taskID === overTaskID; });
  if (fromIdx < 0 || toIdx < 0 || fromIdx === toIdx) return;
  var moved = list.splice(fromIdx, 1)[0];
  list.splice(toIdx, 0, moved);
  renderTable();
}

function onTaskDragEnd(e) {
  if (!dragTaskCtx) return;
  var projectID = dragTaskCtx.projectID;
  var list = PM.tasksByProject[projectID];
  dragTaskCtx = null;
  if (!list) return;
  gasCall('reorderProjectTasks', projectID, list.map(function(t) { return t.taskID; })).catch(function() {});
}

function toggleProject(projectID) {
  PM.expandedProjects[projectID] = !PM.expandedProjects[projectID];
  if (PM.expandedProjects[projectID] && !PM.tasksByProject[projectID]) {
    renderTable(); // show spinner row
    gasCall('getProjectTasks', projectID).then(function(tasks) {
      PM.tasksByProject[projectID] = (tasks && !tasks.error) ? tasks : [];
      renderTable();
    }).catch(function() {
      PM.tasksByProject[projectID] = [];
      renderTable();
    });
  } else {
    renderTable();
  }
}

// ── KANBAN VIEW ───────────────────────────────────────────
function getKanbanCards() {
  var cat = getCategoryFilter();
  var term = getSearchTerm();
  var owner = getOwnerFilter();
  var cards = [];

  PM.allTasks.forEach(function(t) {
    if (cat && t.category !== cat) return;
    if (owner && t.owner !== owner) return;
    if (term && t.taskName.toLowerCase().indexOf(term) < 0 && t.projectName.toLowerCase().indexOf(term) < 0) return;
    cards.push({ type: 'task', id: t.taskID, name: t.taskName, sub: t.projectName, owner: t.owner,
      status: t.status, priority: t.priority, dueDate: t.dueDate, progress: t.progress, category: t.category });
  });

  PM.soloProjects.forEach(function(p) {
    if (cat && p.category !== cat) return;
    if (owner && p.owner !== owner) return;
    if (term && p.projectName.toLowerCase().indexOf(term) < 0) return;
    cards.push({ type: 'project', id: p.projectID, name: p.projectName, sub: p.plantName, owner: p.owner,
      status: p.status, priority: p.priority, dueDate: p.dueDate, progress: p.progress, category: p.category });
  });

  return cards;
}

function renderKanban() {
  var cards = getKanbanCards();
  var board = document.getElementById('kanban-board');
  board.innerHTML = PM.statuses.map(function(status) {
    var colCards = cards.filter(function(c) { return c.status === status; });
    var cardsHtml = colCards.length ? colCards.map(function(c) { return renderKanbanCard(c); }).join('') :
      '<div class="kanban-empty">No items</div>';
    return '<div class="kanban-col" data-status="' + esc(status) + '" ondragover="onColDragOver(event)" ondragleave="onColDragLeave(event)" ondrop="onColDrop(event, \'' + esc(status) + '\')">' +
      '<div class="kanban-col-header"><span class="kanban-col-title">' + esc(status) + '</span><span class="kanban-col-count">' + colCards.length + '</span></div>' +
      '<div class="kanban-cards">' + cardsHtml + '</div>' +
    '</div>';
  }).join('');
}

function renderKanbanCard(c) {
  var typeLabel = c.type === 'task' ? 'Task' : 'Project';
  return '<div class="kanban-card" draggable="true" data-id="' + c.id + '" data-type="' + c.type + '" ondragstart="onCardDragStart(event, \'' + c.id + '\', \'' + c.type + '\')" ondragend="onCardDragEnd(event)" onclick="' + (c.type === 'task' ? "openTaskModal('" + c.id + "', null)" : "openProjectModal('" + c.id + "')") + '">' +
    '<div class="kanban-card-title">' + esc(c.name) + '</div>' +
    '<div class="kanban-card-meta">' + esc(c.sub) + ' &middot; <span class="badge badge-type">' + typeLabel + '</span></div>' +
    '<div class="progress-wrap" style="margin-bottom:8px"><div class="progress-track"><div class="progress-fill' + (c.progress>=100?' complete':'') + '" style="width:' + c.progress + '%"></div></div><span class="progress-text">' + c.progress + '%</span></div>' +
    '<div class="kanban-card-footer">' +
      '<span class="badge ' + prioClass(c.priority) + '">' + esc(c.priority) + '</span>' +
      (c.dueDate ? '<span style="font-size:11px;color:#6b7280">Due ' + fmtDate(c.dueDate) + '</span>' : '') +
      (c.owner ? '<span style="font-size:11px;color:#6b7280">' + esc(c.owner) + '</span>' : '') +
    '</div>' +
  '</div>';
}

// Drag and drop
var dragItem = null;
function onCardDragStart(e, id, type) {
  dragItem = { id: id, type: type };
  e.target.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
}
function onCardDragEnd(e) { e.target.classList.remove('dragging'); }
function onColDragOver(e) { e.preventDefault(); e.currentTarget.classList.add('drag-over'); }
function onColDragLeave(e) { e.currentTarget.classList.remove('drag-over'); }
function onColDrop(e, newStatus) {
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  if (!dragItem) return;
  var item = dragItem; dragItem = null;

  var list = item.type === 'task' ? PM.allTasks : PM.soloProjects;
  var idKey = item.type === 'task' ? 'taskID' : 'projectID';
  var obj = list.find(function(x) { return x[idKey] === item.id; });
  if (!obj || obj.status === newStatus) return;

  var oldStatus = obj.status;
  obj.status = newStatus;
  if (newStatus === 'Completed') obj.progress = 100;
  renderKanban();

  var fn = item.type === 'task' ? 'updateProjectTaskStatus' : 'updateProjectStatus';
  gasCall(fn, item.id, newStatus).then(function(result) {
    if (!result || !result.success) {
      obj.status = oldStatus;
      renderKanban();
      alert('Failed to update status: ' + ((result && result.error) || 'Unknown error'));
    } else {
      loadAll();
    }
  }).catch(function(e) {
    obj.status = oldStatus;
    renderKanban();
    alert('Failed to update status: ' + e.message);
  });
}

// ── GANTT VIEW ────────────────────────────────────────────
var GANTT_PX_PER_DAY = { Day: 36, Week: 16, Month: 5 };
var GANTT_COLORS = {
  'bar-project':    { bg: '#c7d2fe', text: '#3730a3' },
  'bar-backlog':    { bg: '#e5e7eb', text: '#374151' },
  'bar-planned':    { bg: '#93c5fd', text: '#1e3a8a' },
  'bar-inprogress': { bg: '#fdba74', text: '#7c2d12' },
  'bar-onhold':     { bg: '#c4b5fd', text: '#4c1d95' },
  'bar-completed':  { bg: '#86efac', text: '#14532d' }
};

function setGanttMode(mode) {
  PM.ganttMode = mode;
  document.querySelectorAll('#gantt-toolbar button').forEach(function(b) {
    b.classList.toggle('active', b.getAttribute('data-mode') === mode);
  });
  renderGantt();
}

function buildGanttTasks() {
  var cat = getCategoryFilter();
  var term = getSearchTerm();
  var visibleTasks = getVisibleTasks();
  var ganttTasks = [];

  PM.projects.forEach(function(p) {
    if (cat && p.category !== cat) return;
    if (!projectMatchesOwner(p, visibleTasks)) return;

    var tasks = visibleTasks.filter(function(t) { return t.projectID === p.projectID; });
    var matches = !term || p.projectName.toLowerCase().indexOf(term) >= 0 ||
      tasks.some(function(t) { return t.taskName.toLowerCase().indexOf(term) >= 0; });
    if (!matches) return;

    if (tasks.length) {
      // Project bar spans the min/max of its tasks
      var starts = tasks.map(function(t){ return t.startDate; }).filter(Boolean).sort();
      var dues   = tasks.map(function(t){ return t.dueDate; }).filter(Boolean).sort();
      var start = starts.length ? starts[0] : (p.startDate || todayStr());
      var end   = dues.length ? dues[dues.length-1] : (p.dueDate || start);
      if (start === end) end = addDays(end, 1);
      ganttTasks.push({
        id: 'P-' + p.projectID, name: p.projectName, owner: p.owner, start: start, end: end,
        progress: p.progress, custom_class: 'bar-project'
      });
      tasks.forEach(function(t) {
        if (!t.startDate || !t.dueDate) return;
        var s = t.startDate, e = t.dueDate;
        if (s === e) e = addDays(e, 1);
        ganttTasks.push({
          id: 'T-' + t.taskID, name: t.taskName, owner: t.owner, start: s, end: e,
          progress: t.progress, custom_class: 'bar-' + t.status.toLowerCase().replace(/\s/g,'')
        });
      });
    } else if (p.startDate && p.dueDate) {
      var s2 = p.startDate, e2 = p.dueDate;
      if (s2 === e2) e2 = addDays(e2, 1);
      ganttTasks.push({
        id: 'P-' + p.projectID, name: p.projectName, owner: p.owner, start: s2, end: e2,
        progress: p.progress, custom_class: 'bar-' + p.status.toLowerCase().replace(/\s/g,'')
      });
    }
  });

  return ganttTasks;
}

function addDays(dateStr, n) {
  var d = new Date(dateStr + 'T00:00:00');
  d.setDate(d.getDate() + n);
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}

function ganttDaysBetween(a, b) {
  var d1 = new Date(a + 'T00:00:00');
  var d2 = new Date(b + 'T00:00:00');
  return Math.round((d2 - d1) / 86400000);
}

function ganttFmtShort(dateStr) {
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var parts = dateStr.split('-');
  return months[parseInt(parts[1],10)-1] + ' ' + parseInt(parts[2],10);
}

// Builds header column definitions: { label, days } for the given mode
function buildGanttColumns(minDate, totalDays, mode) {
  var cols = [];
  var monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  if (mode === 'Day') {
    for (var i = 0; i < totalDays; i++) {
      var d = addDays(minDate, i);
      var dayNum = parseInt(d.split('-')[2], 10);
      cols.push({ label: (dayNum === 1 ? ganttFmtShort(d) : String(dayNum)), days: 1 });
    }
  } else if (mode === 'Week') {
    var i = 0;
    while (i < totalDays) {
      var d = addDays(minDate, i);
      var span = Math.min(7, totalDays - i);
      cols.push({ label: ganttFmtShort(d), days: span });
      i += 7;
    }
  } else { // Month
    var i = 0;
    while (i < totalDays) {
      var d = addDays(minDate, i);
      var parts = d.split('-');
      var y = parseInt(parts[0],10), m = parseInt(parts[1],10), dayOfMonth = parseInt(parts[2],10);
      var daysInMonth = new Date(y, m, 0).getDate();
      var remaining = daysInMonth - dayOfMonth + 1;
      var span = Math.min(remaining, totalDays - i);
      cols.push({ label: monthNames[m-1] + ' ' + y, days: span });
      i += span;
    }
  }
  return cols;
}

function renderGantt() {
  var wrap = document.getElementById('gantt-wrap');
  var empty = document.getElementById('gantt-empty');
  var ganttTasks = buildGanttTasks();

  if (!ganttTasks.length) {
    wrap.style.display = 'none';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  wrap.style.display = 'flex';

  // Date range with 1-day padding on each side
  var allDates = [];
  ganttTasks.forEach(function(t) { allDates.push(t.start, t.end); });
  allDates.sort();
  var minDate = addDays(allDates[0], -1);
  var maxDate = addDays(allDates[allDates.length - 1], 1);
  var totalDays = Math.max(ganttDaysBetween(minDate, maxDate), 1);

  var pxPerDay = GANTT_PX_PER_DAY[PM.ganttMode] || GANTT_PX_PER_DAY.Week;
  var totalWidth = totalDays * pxPerDay;
  var cols = buildGanttColumns(minDate, totalDays, PM.ganttMode);
  var totalHeight = 32 + ganttTasks.length * 38; // header + body rows

  // Left panel
  var leftHtml = '<div class="gantt-row header-row"><div class="g-name">Name</div><div class="g-owner">Owner</div><div class="g-progress">Progress</div></div>';

  // Right panel header (date columns)
  var rightHtml = '<div class="gantt-row header-row">' +
    cols.map(function(c) { return '<div class="g-col-label" style="width:' + (c.days * pxPerDay) + 'px">' + esc(c.label) + '</div>'; }).join('') +
  '</div>';

  var ganttTasksById = {};

  ganttTasks.forEach(function(t) {
    var isProject = t.id.indexOf('P-') === 0;
    var refID = t.id.substring(2);
    var clickHandler = isProject ? "openProjectModal('" + refID + "')" : "openTaskModal('" + refID + "', null)";
    var nameCls = isProject ? 'g-name' : 'g-name task-indent';
    var progressCls = t.progress >= 100 ? ' complete' : '';
    var draggable = t.custom_class !== 'bar-project'; // project bars w/ tasks are computed, not stored
    ganttTasksById[t.id] = t;

    leftHtml += '<div class="gantt-row" onclick="' + clickHandler + '">' +
      '<div class="' + nameCls + '" title="' + esc(t.name) + '">' + esc(t.name) + '</div>' +
      '<div class="g-owner">' + esc(t.owner || '\u2013') + '</div>' +
      '<div class="g-progress"><div class="progress-track"><div class="progress-fill' + progressCls + '" style="width:' + t.progress + '%"></div></div><span class="g-progress-text">' + t.progress + '%</span></div>' +
    '</div>';

    var leftPx = ganttDaysBetween(minDate, t.start) * pxPerDay;
    var barWidth = Math.max(ganttDaysBetween(t.start, t.end) * pxPerDay, 6);
    var colors = GANTT_COLORS[t.custom_class] || GANTT_COLORS['bar-backlog'];
    var barStyle = 'left:' + leftPx + 'px; width:' + barWidth + 'px; background:' + colors.bg + '; color:' + colors.text;

    if (draggable) {
      rightHtml += '<div class="gantt-row">' +
        '<div class="g-bar" data-bar-id="' + t.id + '" style="' + barStyle + '">' +
          '<div class="g-bar-fill" style="width:' + t.progress + '%"></div>' +
          '<div class="g-bar-overlay">' +
            '<div class="g-handle-left"></div>' +
            '<div class="g-handle-move"><span class="g-bar-label">' + esc(t.name) + '</span></div>' +
            '<div class="g-handle-right"></div>' +
          '</div>' +
        '</div>' +
      '</div>';
    } else {
      rightHtml += '<div class="gantt-row" onclick="' + clickHandler + '">' +
        '<div class="g-bar" style="' + barStyle + '">' +
          '<div class="g-bar-fill" style="width:' + t.progress + '%"></div>' +
          '<span class="g-bar-label">' + esc(t.name) + '</span>' +
        '</div>' +
      '</div>';
    }
  });

  // Today marker
  var today = todayStr();
  var todayOffset = ganttDaysBetween(minDate, today) * pxPerDay;
  if (todayOffset >= 0 && todayOffset <= totalWidth) {
    rightHtml += '<div class="g-today-line" style="left:' + todayOffset + 'px; height:' + totalHeight + 'px"></div>';
  }

  document.getElementById('gantt-left').innerHTML = leftHtml;
  var rightEl = document.getElementById('gantt-right');
  rightEl.style.width = totalWidth + 'px';
  rightEl.style.height = totalHeight + 'px';
  rightEl.innerHTML = rightHtml;

  rightEl.querySelectorAll('.g-bar[data-bar-id]').forEach(function(barEl) {
    var gt = ganttTasksById[barEl.getAttribute('data-bar-id')];
    if (gt) setupGanttBarDrag(barEl, gt, minDate, pxPerDay, totalDays);
  });
}

function ganttClamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

// Wires up drag-to-move / drag-to-resize on a task or solo-project bar.
// Project bars with tasks are not draggable (their span is computed, not stored).
function setupGanttBarDrag(barEl, gt, minDate, pxPerDay, totalDays) {
  var isTask = gt.id.indexOf('T-') === 0;
  var refID = gt.id.substring(2);
  var origStart = ganttDaysBetween(minDate, gt.start);
  var origEnd = ganttDaysBetween(minDate, gt.end);

  function applyPosition(s, e) {
    barEl.style.left = (s * pxPerDay) + 'px';
    barEl.style.width = Math.max((e - s) * pxPerDay, 6) + 'px';
  }

  function persist(s, e) {
    var newStart = addDays(minDate, s);
    var newEnd = addDays(minDate, e);
    var fn = isTask ? 'updateProjectTaskDates' : 'updateProjectDates';
    gasCall(fn, refID, newStart, newEnd).then(function(result) {
      if (result && result.success) { loadAll(); }
      else {
        applyPosition(origStart, origEnd);
        alert('Failed to update dates: ' + ((result && result.error) || 'Unknown error'));
      }
    }).catch(function(err) {
      applyPosition(origStart, origEnd);
      alert('Failed to update dates: ' + err.message);
    });
  }

  function bindHandle(el, type) {
    if (!el) return;
    el.addEventListener('pointerdown', function(e) {
      e.preventDefault();
      e.stopPropagation();
      el.setPointerCapture(e.pointerId);
      var startX = e.clientX;
      var s = origStart, en = origEnd, moved = false;

      function onMove(ev) {
        var dDays = Math.round((ev.clientX - startX) / pxPerDay);
        if (dDays !== 0) moved = true;
        if (type === 'move') {
          var dur = origEnd - origStart;
          s = ganttClamp(origStart + dDays, 0, totalDays - dur);
          en = s + dur;
        } else if (type === 'left') {
          s = ganttClamp(origStart + dDays, 0, origEnd - 1);
          en = origEnd;
        } else {
          en = ganttClamp(origEnd + dDays, origStart + 1, totalDays);
          s = origStart;
        }
        applyPosition(s, en);
      }

      function onUp() {
        el.releasePointerCapture(e.pointerId);
        document.removeEventListener('pointermove', onMove);
        document.removeEventListener('pointerup', onUp);
        if (moved) {
          if (s !== origStart || en !== origEnd) persist(s, en);
        } else if (type === 'move') {
          if (isTask) openTaskModal(refID, null); else openProjectModal(refID);
        }
      }

      document.addEventListener('pointermove', onMove);
      document.addEventListener('pointerup', onUp);
    });
  }

  bindHandle(barEl.querySelector('.g-handle-left'), 'left');
  bindHandle(barEl.querySelector('.g-handle-right'), 'right');
  bindHandle(barEl.querySelector('.g-handle-move'), 'move');
}

