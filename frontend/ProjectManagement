function calNav(delta) {
  PM.calMonth.setMonth(PM.calMonth.getMonth() + delta);
  renderCalendar();
}
function calToday() {
  PM.calMonth = new Date();
  renderCalendar();
}

function getCalendarItems() {
  var cat = getCategoryFilter();
  var term = getSearchTerm();
  var owner = getOwnerFilter();
  var items = [];

  PM.allTasks.forEach(function(t) {
    if (!t.dueDate) return;
    if (cat && t.category !== cat) return;
    if (owner && t.owner !== owner) return;
    if (term && t.taskName.toLowerCase().indexOf(term) < 0 && t.projectName.toLowerCase().indexOf(term) < 0) return;
    items.push({ type: 'task', id: t.taskID, name: t.taskName, date: t.dueDate, status: t.status });
  });
  PM.soloProjects.forEach(function(p) {
    if (!p.dueDate) return;
    if (cat && p.category !== cat) return;
    if (owner && p.owner !== owner) return;
    if (term && p.projectName.toLowerCase().indexOf(term) < 0) return;
    items.push({ type: 'project', id: p.projectID, name: p.projectName, date: p.dueDate, status: p.status });
  });
  return items;
}

function renderCalendar() {
  var year = PM.calMonth.getFullYear();
  var month = PM.calMonth.getMonth();
  var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('cal-title').textContent = monthNames[month] + ' ' + year;

  var items = getCalendarItems();
  var itemsByDate = {};
  items.forEach(function(it) {
    if (!itemsByDate[it.date]) itemsByDate[it.date] = [];
    itemsByDate[it.date].push(it);
  });

  var firstDay = new Date(year, month, 1);
  var startOffset = firstDay.getDay(); // 0=Sun
  var daysInMonth = new Date(year, month + 1, 0).getDate();
  var daysInPrevMonth = new Date(year, month, 0).getDate();
  var today = todayStr();

  var dowNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var html = dowNames.map(function(d){ return '<div class="cal-dow">' + d + '</div>'; }).join('');

  var totalCells = Math.ceil((startOffset + daysInMonth) / 7) * 7;
  for (var i = 0; i < totalCells; i++) {
    var dayNum, cellMonth = month, cellYear = year, otherMonth = false;
    if (i < startOffset) {
      dayNum = daysInPrevMonth - (startOffset - i - 1);
      cellMonth = month - 1; if (cellMonth < 0) { cellMonth = 11; cellYear--; }
      otherMonth = true;
    } else if (i >= startOffset + daysInMonth) {
      dayNum = i - (startOffset + daysInMonth) + 1;
      cellMonth = month + 1; if (cellMonth > 11) { cellMonth = 0; cellYear++; }
      otherMonth = true;
    } else {
      dayNum = i - startOffset + 1;
    }
    var dateStr = cellYear + '-' + String(cellMonth+1).padStart(2,'0') + '-' + String(dayNum).padStart(2,'0');
    var isToday = dateStr === today;
    var dayItems = itemsByDate[dateStr] || [];

    html += '<div class="cal-cell' + (otherMonth ? ' other-month' : '') + (isToday ? ' today' : '') + '">' +
      '<div class="cal-date">' + dayNum + '</div>' +
      dayItems.map(function(it) {
        var onclick = it.type === 'task' ? "openTaskModal('" + it.id + "', null)" : "openProjectModal('" + it.id + "')";
        return '<div class="cal-chip ' + calChipClass(it.status) + '" onclick="' + onclick + '" title="' + esc(it.name) + '">' + esc(it.name) + '</div>';
      }).join('') +
    '</div>';
  }

  document.getElementById('cal-grid').innerHTML = html;
}

